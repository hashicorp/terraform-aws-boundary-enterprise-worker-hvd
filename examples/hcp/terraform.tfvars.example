# --- Provider --- #
region = "us-east-2"

# ---Common --- #
friendly_name_prefix = "<acme-hcp>" #This should be unique across all deployments
common_tags = {
  App         = "<boundary-worker>"
  Env         = "<sandbox>"
  Owner       = "<YourName>"
  worker-type = "<hcp>"
}

# ---Boundary configuration settings --- #
boundary_version         = "<0.21.3+ent>"
worker_registration_method            = "<worker-led>"      # Method for registering the worker with the Boundary cluster. Supported values are `worker-led`, `controller-led`, and `kms-led`.
kms_worker_arn                        = <"">                # KMS worker ARN must be a valid KMS key ARN when `worker_registration_method` is set to `kms-led`.
kms_endpoint                          = <"">                # KMS endpoint must be a valid AWS service endpoint when `worker_registration_method` is set to `kms-led`.
controller_generated_activation_token = <"">                # Activation token generated by the controller. Required if `worker_registration_method` is set to `controller-led`."
worker_is_internal       = <false>
enable_session_recording = <false>
hcp_boundary_cluster_id  = "<id>" # The cluster ID is the top-most subdomain portion of the FQDN Cluster URL, e.g., if the cluster URL in the HCP Boundary admin UI is https://e9842b6b-b2b4-51c2-c4aa-b7c4dea9810c.boundary.hashicorp.cloud/ the cluster ID is e9842b6b-b2b4-51c2-c4aa-b7c4dea9810c
worker_tags = {
  bsr = "enabled"
}

# --- EC2 --- #
ec2_instance_size = "<m5.2xlarge>" #For production, m5.2xlarge is recommended. Can change to smaller instance for testing, e.g., t2.medium although a minimum amount of memory may be required even for testing. See https://developer.hashicorp.com/boundary/docs/architecture/system-requirements for more details.

# --- Networking --- #
vpc_id                           = "<my-vpc-id>"
worker_subnet_ids                = ["<my-worker-subnet-id-a>", "<my-worker-subnet-id-b>", "<my-worker-subnet-id-c>"]
cidr_allow_ingress_boundary_9202 = ["<10.0.0.0/16>"]
cidr_allow_ingress_ec2_ssh       = ["<10.0.0.0/16>"]
create_lb                        = <false>

# --- IAM --- #
create_boundary_worker_role              = <true> # If set to false, you must provide an existing AWS boundary worker role name in the variable below
boundary_worker_iam_role_name            = <null>

# --- S3 --- #
bsr_s3_bucket_arn = "<existing-bucket-arn>"
